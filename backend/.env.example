NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ehcp
REDIS_URL=redis://localhost:6379
JWT_ACCESS_SECRET=replace_with_very_long_access_secret_value_32_plus
JWT_REFRESH_SECRET=replace_with_very_long_refresh_secret_value_32_plus
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
BRUTE_FORCE_WINDOW_SECONDS=900
BRUTE_FORCE_MAX_ATTEMPTS=5
LOCKOUT_MINUTES=15
ENCRYPTION_KEY=replace_with_32_characters_minimum_secret_key
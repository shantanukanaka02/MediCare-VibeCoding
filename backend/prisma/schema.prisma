generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  ACTIVE
  INACTIVE
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum TaskStatus {
  NEW
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELED
}

enum AppointmentStatus {
  SCHEDULED
  CHECKED_IN
  COMPLETED
  CANCELED
  NO_SHOW
}

enum IntakeState {
  DRAFT
  SUBMITTED
  TRIAGE_PENDING
  TRIAGED
  ASSIGNED_TO_DOCTOR
  CONSULTED
  TREATMENT_STARTED
  COMPLETED
  FOLLOW_UP_REQUIRED
}

enum TriagePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TreatmentPlanStatus {
  DRAFT
  REVIEW
  APPROVED
  ACTIVE
  MODIFIED
  CLOSED
}

enum LabOrderStatus {
  ORDERED
  SAMPLE_COLLECTED
  PROCESSING
  RESULTS_UPLOADED
  DOCTOR_REVIEWED
  PATIENT_NOTIFIED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum ApprovalType {
  CONTROLLED_SUBSTANCE
  INSURANCE_PREAUTH
  CLINICAL_REVIEW
}

enum BillingTriggerStatus {
  PENDING
  EMITTED
  FAILED
}

model Organization {
  id                   String                      @id @default(uuid())
  name                 String
  status               OrganizationStatus          @default(ACTIVE)
  createdAt            DateTime                    @default(now()) @map("created_at")
  users                User[]
  roles                Role[]
  userRoles            UserRole[]
  refreshTokens        RefreshToken[]
  patients             Patient[]
  tasks                Task[]
  appointments         Appointment[]
  triageCases          TriageCase[]
  treatmentPlans       TreatmentPlan[]
  labOrders            LabOrder[]
  approvals            Approval[]
  billingTriggers      BillingTrigger[]
  workflowTransitions  WorkflowTransitionHistory[]
  auditLogs            AuditLog[]

  @@map("organizations")
}

model User {
  id                    String                      @id @default(uuid())
  organizationId        String                      @map("organization_id")
  organization          Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  email                 String
  passwordHash          String                      @map("password_hash")
  status                UserStatus                  @default(ACTIVE)
  failedLoginCount      Int                         @default(0) @map("failed_login_count")
  lockedUntil           DateTime?                   @map("locked_until")
  createdAt             DateTime                    @default(now()) @map("created_at")
  updatedAt             DateTime                    @updatedAt @map("updated_at")
  userRoles             UserRole[]
  refreshTokens         RefreshToken[]
  assignedTasks         Task[]                      @relation("TaskAssignee")
  createdTasks          Task[]                      @relation("TaskCreator")
  appointmentsProvided  Appointment[]               @relation("AppointmentProvider")
  appointmentsCreated   Appointment[]               @relation("AppointmentCreator")
  triageCreated         TriageCase[]                @relation("TriageCreator")
  triageAssignedDoctor  TriageCase[]                @relation("TriageAssignedDoctor")
  treatmentPlansCreated TreatmentPlan[]             @relation("TreatmentPlanCreator")
  treatmentPlansApproved TreatmentPlan[]            @relation("TreatmentPlanApprover")
  labOrdersOrdered      LabOrder[]                  @relation("LabOrderOrderer")
  labOrdersReviewed     LabOrder[]                  @relation("LabOrderReviewer")
  approvalsRequested    Approval[]                  @relation("ApprovalRequester")
  approvalsDecided      Approval[]                  @relation("ApprovalDecider")
  billingTriggersCreated BillingTrigger[]           @relation("BillingTriggerCreator")
  workflowTransitions   WorkflowTransitionHistory[] @relation("TransitionActor")
  auditLogs             AuditLog[]                  @relation("AuditActor")

  @@unique([organizationId, email])
  @@index([organizationId, id])
  @@map("users")
}

model Role {
  id               String           @id @default(uuid())
  organizationId   String           @map("organization_id")
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name             String
  isSystem         Boolean          @default(false) @map("is_system")
  rolePermissions  RolePermission[]
  userRoles        UserRole[]

  @@unique([organizationId, name])
  @@index([organizationId, id])
  @@map("roles")
}

model Permission {
  id               String           @id @default(uuid())
  resource         String
  action           String
  rolePermissions  RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId        String
  permissionId  String
  role          Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission    Permission  @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId           String
  roleId           String
  organizationId   String       @map("organization_id")
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role             Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@id([userId, roleId, organizationId])
  @@index([organizationId, userId])
  @@map("user_roles")
}

model RefreshToken {
  id             String       @id @default(uuid())
  userId         String       @map("user_id")
  organizationId String       @map("organization_id")
  tokenHash      String       @map("token_hash")
  familyId       String       @map("family_id")
  jti            String       @unique
  expiresAt      DateTime     @map("expires_at")
  revokedAt      DateTime?    @map("revoked_at")
  replacedByJti  String?      @map("replaced_by_jti")
  createdAt      DateTime     @default(now()) @map("created_at")
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model Patient {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  externalRef    String?      @map("external_ref")
  mrn            String
  firstNameEnc   String       @map("first_name_enc")
  lastNameEnc    String       @map("last_name_enc")
  dobEnc         String       @map("dob_enc")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  tasks          Task[]
  appointments   Appointment[]
  triageCases    TriageCase[]
  treatmentPlans TreatmentPlan[]
  labOrders      LabOrder[]
  approvals      Approval[]
  billingTriggers BillingTrigger[]

  @@unique([organizationId, mrn])
  @@index([organizationId, id])
  @@map("patients")
}

model Task {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId      String?      @map("patient_id")
  patient        Patient?     @relation(fields: [patientId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  status         TaskStatus   @default(NEW)
  assigneeUserId String?      @map("assignee_user_id")
  assignee       User?        @relation("TaskAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  dueAt          DateTime?    @map("due_at")
  version        Int          @default(1)
  createdBy      String       @map("created_by")
  creator        User         @relation("TaskCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, status])
  @@index([organizationId, assigneeUserId])
  @@map("tasks")
}

model Appointment {
  id                  String            @id @default(uuid())
  organizationId      String            @map("organization_id")
  organization        Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId           String            @map("patient_id")
  patient             Patient           @relation(fields: [patientId], references: [id], onDelete: Restrict)
  providerUserId      String            @map("provider_user_id")
  provider            User              @relation("AppointmentProvider", fields: [providerUserId], references: [id], onDelete: Restrict)
  appointmentType     String            @map("appointment_type")
  scheduledAt         DateTime          @map("scheduled_at")
  endsAt              DateTime          @map("ends_at")
  durationMinutes     Int               @map("duration_minutes")
  requiresOperatingRoom Boolean         @default(false) @map("requires_operating_room")
  roomId              String?           @map("room_id")
  equipmentJson       Json?             @map("equipment_json")
  status              AppointmentStatus @default(SCHEDULED)
  version             Int               @default(1)
  createdBy           String            @map("created_by")
  creator             User              @relation("AppointmentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, providerUserId, scheduledAt])
  @@index([organizationId, status])
  @@map("appointments")
}

model TriageCase {
  id                  String         @id @default(uuid())
  organizationId      String         @map("organization_id")
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId           String         @map("patient_id")
  patient             Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  intakeState         IntakeState    @default(DRAFT) @map("intake_state")
  priority            TriagePriority @default(MEDIUM)
  symptomsJson        Json?          @map("symptoms_json")
  vitalsJson          Json?          @map("vitals_json")
  assignedDoctorId    String?        @map("assigned_doctor_id")
  assignedDoctor      User?          @relation("TriageAssignedDoctor", fields: [assignedDoctorId], references: [id], onDelete: SetNull)
  createdBy           String         @map("created_by")
  creator             User           @relation("TriageCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  version             Int            @default(1)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, intakeState, priority])
  @@index([organizationId, assignedDoctorId])
  @@map("triage_cases")
}

model TreatmentPlan {
  id                  String              @id @default(uuid())
  organizationId      String              @map("organization_id")
  organization        Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId           String              @map("patient_id")
  patient             Patient             @relation(fields: [patientId], references: [id], onDelete: Restrict)
  status              TreatmentPlanStatus @default(DRAFT)
  diagnosesJson       Json?               @map("diagnoses_json")
  medicationsJson     Json?               @map("medications_json")
  labTestsJson        Json?               @map("lab_tests_json")
  proceduresJson      Json?               @map("procedures_json")
  createdBy           String              @map("created_by")
  creator             User                @relation("TreatmentPlanCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  approvedBy          String?             @map("approved_by")
  approver            User?               @relation("TreatmentPlanApprover", fields: [approvedBy], references: [id], onDelete: SetNull)
  version             Int                 @default(1)
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")
  approvals           Approval[]
  billingTriggers     BillingTrigger[]

  @@index([organizationId, id])
  @@index([organizationId, patientId, status])
  @@map("treatment_plans")
}

model LabOrder {
  id                  String         @id @default(uuid())
  organizationId      String         @map("organization_id")
  organization        Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId           String         @map("patient_id")
  patient             Patient        @relation(fields: [patientId], references: [id], onDelete: Restrict)
  orderedByUserId     String         @map("ordered_by_user_id")
  orderedBy           User           @relation("LabOrderOrderer", fields: [orderedByUserId], references: [id], onDelete: Restrict)
  testCode            String         @map("test_code")
  testName            String         @map("test_name")
  status              LabOrderStatus @default(ORDERED)
  resultSummary       String?        @map("result_summary")
  resultDocumentUrl   String?        @map("result_document_url")
  reviewedByUserId    String?        @map("reviewed_by_user_id")
  reviewedBy          User?          @relation("LabOrderReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  orderedAt           DateTime       @default(now()) @map("ordered_at")
  sampleCollectedAt   DateTime?      @map("sample_collected_at")
  reviewedAt          DateTime?      @map("reviewed_at")
  version             Int            @default(1)
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, status, orderedAt])
  @@index([organizationId, patientId])
  @@map("lab_orders")
}

model Approval {
  id                      String         @id @default(uuid())
  organizationId          String         @map("organization_id")
  organization            Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId               String?        @map("patient_id")
  patient                 Patient?       @relation(fields: [patientId], references: [id], onDelete: SetNull)
  treatmentPlanId         String?        @map("treatment_plan_id")
  treatmentPlan           TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  approvalType            ApprovalType   @map("approval_type")
  status                  ApprovalStatus @default(PENDING)
  requiredRole            String         @map("required_role")
  requestedByUserId       String         @map("requested_by_user_id")
  requestedBy             User           @relation("ApprovalRequester", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  decisionByUserId        String?        @map("decision_by_user_id")
  decisionBy              User?          @relation("ApprovalDecider", fields: [decisionByUserId], references: [id], onDelete: SetNull)
  decisionReason          String?        @map("decision_reason")
  metadataJson            Json?          @map("metadata_json")
  escalationRole          String?        @map("escalation_role")
  version                 Int            @default(1)
  createdAt               DateTime       @default(now()) @map("created_at")
  updatedAt               DateTime       @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, status, requiredRole])
  @@index([organizationId, treatmentPlanId])
  @@map("approvals")
}

model BillingTrigger {
  id                  String               @id @default(uuid())
  organizationId      String               @map("organization_id")
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  patientId           String?              @map("patient_id")
  patient             Patient?             @relation(fields: [patientId], references: [id], onDelete: SetNull)
  treatmentPlanId     String?              @map("treatment_plan_id")
  treatmentPlan       TreatmentPlan?       @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  sourceEntityType    String               @map("source_entity_type")
  sourceEntityId      String               @map("source_entity_id")
  triggerType         String               @map("trigger_type")
  status              BillingTriggerStatus @default(PENDING)
  version             Int                  @default(1)
  payloadJson         Json?                @map("payload_json")
  emittedAt           DateTime?            @map("emitted_at")
  failureReason       String?              @map("failure_reason")
  createdBy           String               @map("created_by")
  creator             User                 @relation("BillingTriggerCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  @@index([organizationId, id])
  @@index([organizationId, status, triggerType])
  @@index([organizationId, sourceEntityType, sourceEntityId])
  @@map("billing_triggers")
}

model WorkflowTransitionHistory {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  entityType     String       @map("entity_type")
  entityId       String       @map("entity_id")
  fromState      String       @map("from_state")
  toState        String       @map("to_state")
  event          String
  actorUserId    String       @map("actor_user_id")
  actor          User         @relation("TransitionActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  reason         String?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, id])
  @@index([organizationId, entityType, entityId, createdAt])
  @@map("workflow_transition_history")
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  actorUserId    String?      @map("actor_user_id")
  actor          User?        @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action         String
  entityType     String       @map("entity_type")
  entityId       String       @map("entity_id")
  beforeJson     Json?        @map("before_json")
  afterJson      Json?        @map("after_json")
  requestId      String       @map("request_id")
  ip             String?
  userAgent      String?      @map("user_agent")
  createdAt      DateTime     @default(now()) @map("created_at")

  @@index([organizationId, id])
  @@index([organizationId, entityType, entityId, createdAt])
  @@map("audit_logs")
}
